{:deps true
 :dev-http {8080 "public"}
 :builds
 {:app
  {:target :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules {:main {:init-fn fdg.runner/init!}}
   :devtools {:after-load fdg.runner/render!}}
  :smoke
  {:target :node-script
   :output-to "target/smoke.js"
   :main fdg.smoke/main}}}
